# Smart eCommerce Intelligence Pipeline — environment template
# Copy to .env and fill as needed.

# Scraping (optional: rate limits, auth)
# SHOPIFY_STORE=
# WOOCOMMERCE_URL=
# WOOCOMMERCE_KEY=
# WOOCOMMERCE_SECRET=

# LLM (optional: for summary generation)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=   # e.g. for local/open-source endpoint

# Paths (defaults work with repo layout)
# DATA_DIR=./data
# RAW_DIR=./data/raw
# PROCESSED_DIR=./data/processed
# ANALYTICS_DIR=./data/analytics
